<?xml version="1.0" encoding="utf-8"?>
<!--
  Bu profil, .NET Runtime gerektirmeden çalışan tek klasör çıktısı üretir.
  Kullanım (terminal):
    dotnet publish -p:PublishProfile=SelfContained
  Çıktı: bin\Release\net10.0-windows\win-x64\publish\
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishDir>bin\Release\net10.0-windows\win-x64\publish\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
  </PropertyGroup>
</Project>
